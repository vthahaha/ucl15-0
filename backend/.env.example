# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API-Football Configuration
# Set API_PROVIDER to 'api-sports' (direct) or 'rapidapi'
API_PROVIDER=api-sports
API_SPORTS_KEY=your-api-sports-key

# RapidAPI Configuration (only used if API_PROVIDER=rapidapi)
RAPIDAPI_KEY=your-rapidapi-key
RAPIDAPI_HOST=api-football-v1.p.rapidapi.com

# UCL Ingestion Settings
# League ID for UEFA Champions League is typically 2
UCL_LEAGUE_ID=2
# Seasons to fetch (comma-separated start years)
# 1992 corresponds to 1992/1993, 2025 corresponds to 2025/2026
START_SEASON=1992
END_SEASON=2025
